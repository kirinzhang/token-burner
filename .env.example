# Token Burner — API 配置

# OpenAI API Key（必填）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Base URL（可选，用于代理或自定义 Endpoint）
# 默认：https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 费用上限（USD），超过后自动停止任务
# 默认：10
COST_LIMIT_USD=10

# 默认模型
# 可选：gpt-4o | gpt-4o-mini | gpt-3.5-turbo | o3-mini
DEFAULT_MODEL=gpt-4o-mini
